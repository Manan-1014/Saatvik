{
  "name": "workspace",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "preinstall": "node scripts/check-package-manager.js",
    "dev": "dotenv -e .env -- turbo dev --filter=@workspace/api-server --filter=@workspace/tiffin-web",
    "dev:api": "dotenv -e .env -- sh -c 'PORT=$API_PORT pnpm --filter @workspace/api-server dev'",
    "dev:web": "dotenv -e .env -- sh -c 'PORT=$WEB_PORT API_SERVER_URL=${API_SERVER_URL:-http://localhost:$API_PORT} pnpm --filter @workspace/tiffin-web dev'",
    "setup": "pnpm install && pnpm run db:push && pnpm run db:seed",
    "setup:fresh": "pnpm run clean && pnpm run setup",
    "db:push": "dotenv -e .env -- pnpm --filter @workspace/db push",
    "db:push-force": "dotenv -e .env -- pnpm --filter @workspace/db push-force",
    "db:seed": "dotenv -e .env -- pnpm --filter @workspace/scripts exec tsx ../artifacts/api-server/seed.mjs",
    "db:studio": "dotenv -e .env -- pnpm --filter @workspace/db studio",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "typecheck:libs": "tsc --build",
    "lint": "pnpm -r --if-present run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "test": "pnpm -r --if-present run test",
    "test:ci": "pnpm -r --if-present run test:ci",
    "clean": "pnpm -r --if-present run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.6",
    "typescript": "~5.9.2"
  }
}