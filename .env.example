# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/DB_NAME

# ─────────────────────────────────────────────
# API Server  (@workspace/api-server)
# ─────────────────────────────────────────────
API_PORT=3001

# Secret used to sign JWT tokens — change this in production!
SESSION_SECRET=change-me-to-a-long-random-string

# Optional: pino log level (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info

# ─────────────────────────────────────────────
# Razorpay  (https://dashboard.razorpay.com)
# ─────────────────────────────────────────────
# Use test keys (rzp_test_*) for development, live keys (rzp_live_*) for production.
# Key Id + Key Secret must be from the same mode (test vs live) and the same account.
# If Razorpay returns "Authentication failed", regenerate the secret in Dashboard and paste again (no quotes/spaces).
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─────────────────────────────────────────────
# Web Frontend  (@workspace/tiffin-web)
# ─────────────────────────────────────────────
WEB_PORT=3000

# Vite base path — keep "/" unless you're serving under a sub-path
BASE_PATH=/

# Razorpay public key exposed to the browser (KEY ID only — never the secret)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
