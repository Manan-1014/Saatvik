# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/DB_NAME

# ─────────────────────────────────────────────
# API Server  (@workspace/api-server)
# ─────────────────────────────────────────────
API_PORT=3001

# Secret used to sign JWT tokens — change this in production!
SESSION_SECRET=change-me-to-a-long-random-string

# Optional: pino log level (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info

# ─────────────────────────────────────────────
# Web Frontend  (@workspace/tiffin-web)
# ─────────────────────────────────────────────
WEB_PORT=3000

# Vite base path — keep "/" unless you're serving under a sub-path
BASE_PATH=/
